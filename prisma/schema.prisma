generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WorkspaceType {
  personal
  team

  @@map("workspace_type")
}

enum WorkspaceRole {
  owner
  admin
  member

  @@map("workspace_role")
}

enum InvitationStatus {
  pending
  accepted
  revoked

  @@map("invitation_status")
}

enum GoalStatus {
  active
  done
  abandoned

  @@map("goal_status")
}

enum ProjectMethod {
  scrum
  kanban
  fdd
  simple

  @@map("project_method")
}

enum ProjectStatus {
  active
  paused
  archived

  @@map("project_status")
}

enum TaskPriority {
  low
  medium
  high

  @@map("task_priority")
}

enum TaskStatus {
  todo
  in_progress
  done

  @@map("task_status")
}

enum SprintStatus {
  planned
  active
  closed

  @@map("sprint_status")
}

enum ProjectRoleType {
  po
  sm
  dev

  @@map("project_role_type")
}

enum HabitStatus {
  detected
  analysis
  correction
  verification
  overcome

  @@map("habit_status")
}

enum HabitSeverity {
  low
  medium
  high

  @@map("habit_severity")
}

enum CheckinResult {
  done
  occurrence
  skipped

  @@map("checkin_result")
}

enum InvariantStatus {
  holding
  violated

  @@map("invariant_status")
}

enum FeatureStatus {
  design
  design_reviewed
  build
  build_reviewed
  done

  @@map("feature_status")
}

enum PrototypeKind {
  throwaway
  evolutionary

  @@map("prototype_kind")
}

enum RoutineDecision {
  evolve
  discard
  approve

  @@map("routine_decision")
}

enum EvaluationResult {
  met
  not_met

  @@map("evaluation_result")
}

enum GoalLinkType {
  depends_on
  refines
  conflicts

  @@map("goal_link_type")
}

model Workspace {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  type      WorkspaceType
  // References auth.users(id); no FK because the auth schema is managed by Supabase.
  ownerId   String        @map("owner_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  members     WorkspaceMember[]
  areas       LifeArea[]
  goals       Goal[]
  projects    Project[]
  tasks       Task[]
  invitations WorkspaceInvitation[]
  habits      Habit[]
  invariants  Invariant[]
  routines    Routine[]

  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id            String           @id @default(uuid()) @db.Uuid
  workspaceId   String           @map("workspace_id") @db.Uuid
  email         String
  role          WorkspaceRole    @default(member)
  // Random unguessable token; the acceptance link carries it.
  token         String           @unique
  status        InvitationStatus @default(pending)
  // Both reference auth.users(id); no FK (auth schema is managed by Supabase).
  invitedById   String           @map("invited_by_id") @db.Uuid
  acceptedById  String?          @map("accepted_by_id") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invitations")
}

model Profile {
  // 1:1 with auth.users(id); created on signup.
  userId      String   @id @map("user_id") @db.Uuid
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("profiles")
}

model LifeArea {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String
  color       String?
  icon        String?
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goals     Goal[]
  projects  Project[]

  @@index([workspaceId])
  @@map("life_areas")
}

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  areaId      String     @map("area_id") @db.Uuid
  title       String
  description String?
  targetDate  DateTime?  @map("target_date") @db.Date
  status      GoalStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  area          LifeArea     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projects      Project[]
  tasks         Task[]
  featureSets   FeatureSet[]
  outgoingLinks GoalLink[]   @relation("GoalLinkFrom")
  incomingLinks GoalLink[]   @relation("GoalLinkTo")

  @@index([workspaceId])
  @@index([areaId])
  @@map("goals")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  areaId      String        @map("area_id") @db.Uuid
  goalId      String?       @map("goal_id") @db.Uuid
  name        String
  description String?
  method      ProjectMethod
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  area      LifeArea      @relation(fields: [areaId], references: [id], onDelete: Cascade)
  goal      Goal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)
  boards    Board[]
  tasks     Task[]
  sprints   Sprint[]
  roles     ProjectRole[]

  @@index([workspaceId])
  @@index([areaId])
  @@index([goalId])
  @@map("projects")
}

model Board {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@index([projectId])
  @@map("boards")
}

model BoardColumn {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @map("board_id") @db.Uuid
  name      String
  position  Int      @default(0)
  wipLimit  Int?     @map("wip_limit")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
  @@map("board_columns")
}

model Task {
  id               String       @id @default(uuid()) @db.Uuid
  workspaceId      String       @map("workspace_id") @db.Uuid
  projectId        String?      @map("project_id") @db.Uuid
  goalId           String?      @map("goal_id") @db.Uuid
  columnId         String?      @map("column_id") @db.Uuid
  title            String
  description      String?
  priority         TaskPriority @default(medium)
  estimate         Int?
  status           TaskStatus   @default(todo)
  position         Int          @default(0)
  dueDate          DateTime?    @map("due_date") @db.Date
  sprintId         String?      @map("sprint_id") @db.Uuid
  featureId        String?      @map("feature_id") @db.Uuid
  assigneeId       String?      @map("assignee_id") @db.Uuid
  definitionOfDone Json?        @map("definition_of_done") @db.JsonB
  inbox            Boolean      @default(false)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal        Goal?            @relation(fields: [goalId], references: [id], onDelete: SetNull)
  column      BoardColumn?     @relation(fields: [columnId], references: [id], onDelete: SetNull)
  sprint      Sprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  feature     Feature?         @relation(fields: [featureId], references: [id], onDelete: SetNull)
  transitions TaskTransition[]

  @@index([workspaceId])
  @@index([workspaceId, dueDate])
  @@index([projectId])
  @@index([goalId])
  @@index([columnId])
  @@index([sprintId])
  @@index([featureId])
  @@map("tasks")
}

// Event table: INSERT-only, immutable. Metrics (cycle/lead time, throughput) derive from here.
// from/to column ids are stored without FK so the audit trail survives column deletion.
model TaskTransition {
  id           String      @id @default(uuid()) @db.Uuid
  taskId       String      @map("task_id") @db.Uuid
  fromColumnId String?     @map("from_column_id") @db.Uuid
  toColumnId   String?     @map("to_column_id") @db.Uuid
  fromStatus   TaskStatus? @map("from_status")
  toStatus     TaskStatus  @map("to_status")
  actorId      String      @map("actor_id") @db.Uuid
  at           DateTime    @default(now()) @db.Timestamptz(6)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([at])
  @@map("task_transitions")
}

model Sprint {
  id        String       @id @default(uuid()) @db.Uuid
  projectId String       @map("project_id") @db.Uuid
  name      String
  startsAt  DateTime     @map("starts_at") @db.Date
  endsAt    DateTime     @map("ends_at") @db.Date
  status    SprintStatus @default(planned)
  // Derived at close time from the transition log; stored for history (RF2.5/2.8).
  velocity  Int?
  summaryMd String?      @map("summary_md")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks         Task[]
  retrospective Retrospective?

  @@index([projectId])
  @@map("sprints")
}

model Retrospective {
  id        String   @id @default(uuid()) @db.Uuid
  sprintId  String   @unique @map("sprint_id") @db.Uuid
  wentWell  String?  @map("went_well")
  toImprove String?  @map("to_improve")
  actions   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@map("retrospectives")
}

model ProjectRole {
  projectId String          @map("project_id") @db.Uuid
  // References auth.users(id); no FK because the auth schema is managed by Supabase.
  userId    String          @map("user_id") @db.Uuid
  role      ProjectRoleType
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_roles")
}

// Data-driven state machine definitions (RF6.5). A single engine in
// domain/formal/machine.ts reads these rows to decide whether a transition is
// valid; habit (M5) and feature (M4) flows are seeded here, never hardcoded.
model StateMachine {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  // { initial: string, states: string[] }
  states      Json     @db.JsonB
  // Array of { from, to, event }
  transitions Json     @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("state_machines")
}

// A default habit under correction (M5, RF5.1). Its lifecycle is driven by the
// `habit` state machine; the verification rule is fixed for the whole version
// (RF5.5) — renegotiating it opens a new version.
model Habit {
  id               String        @id @default(uuid()) @db.Uuid
  workspaceId      String        @map("workspace_id") @db.Uuid
  // References auth.users(id); no FK because the auth schema is managed by Supabase.
  ownerId          String        @map("owner_id") @db.Uuid
  name             String
  triggerText      String?       @map("trigger_text")
  severity         HabitSeverity @default(medium)
  status           HabitStatus   @default(detected)
  version          Int           @default(1)
  // Baseline phase length in days before moving to correction (RF5.3).
  analysisDays     Int           @default(7) @map("analysis_days")
  // { condition: "done", windowDays: number, tolerance: number } — immutable
  // during the cycle (RF5.5).
  verificationRule Json          @map("verification_rule") @db.JsonB
  // Optional team witness who validates check-ins (RF5.4). References auth.users(id).
  witnessId        String?       @map("witness_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  checkins    HabitCheckin[]
  transitions HabitTransition[]

  @@index([workspaceId])
  @@map("habits")
}

// Event table: one immutable check-in per habit per day (RF5.4/5.7). A witness
// may later set `validatedBy` (the single set-once field); the result is fixed.
model HabitCheckin {
  id          String        @id @default(uuid()) @db.Uuid
  habitId     String        @map("habit_id") @db.Uuid
  date        DateTime      @db.Date
  result      CheckinResult
  note        String?
  // The witness (auth.users id) who validated this check-in, if any.
  validatedBy String?       @map("validated_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@map("habit_checkins")
}

// Event table: INSERT-only lifecycle log of a habit (RF5.2/5.6/5.7). A relapse
// is just a verification -> correction row; history is never deleted.
model HabitTransition {
  id         String       @id @default(uuid()) @db.Uuid
  habitId    String       @map("habit_id") @db.Uuid
  fromStatus HabitStatus? @map("from_status")
  toStatus   HabitStatus  @map("to_status")
  reason     String?
  actorId    String       @map("actor_id") @db.Uuid
  at         DateTime     @default(now()) @db.Timestamptz(6)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId])
  @@index([at])
  @@map("habit_transitions")
}

// A declarative invariant over the workspace's data (RF6.2). The `rule` is a
// small JSON DSL evaluated by domain/formal/invariant.ts on relevant events.
model Invariant {
  id          String          @id @default(uuid()) @db.Uuid
  workspaceId String          @map("workspace_id") @db.Uuid
  // Optional owner (personal invariant); null means workspace-wide. auth.users id.
  ownerId     String?         @map("owner_id") @db.Uuid
  name        String
  // { type, ... } — see domain/formal/invariant.ts
  rule        Json            @db.JsonB
  status      InvariantStatus @default(holding)
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace  Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  violations InvariantViolation[]

  @@index([workspaceId])
  @@map("invariants")
}

// Event table: one immutable row per invariant violation (RF6.4), carrying the
// event that caused it and enough detail to explain the breach.
model InvariantViolation {
  id          String   @id @default(uuid()) @db.Uuid
  invariantId String   @map("invariant_id") @db.Uuid
  // Event name that triggered evaluation (e.g. "task_moved", "day_closed").
  triggeredBy String   @map("triggered_by_event")
  details     Json     @db.JsonB
  at          DateTime @default(now()) @db.Timestamptz(6)

  invariant Invariant @relation(fields: [invariantId], references: [id], onDelete: Cascade)

  @@index([invariantId])
  @@index([at])
  @@map("invariant_violations")
}

// --- FDD (M4) -------------------------------------------------------------

// A group of features under a goal (RF4.1).
model FeatureSet {
  id        String   @id @default(uuid()) @db.Uuid
  goalId    String   @map("goal_id") @db.Uuid
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  goal     Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  features Feature[]

  @@index([goalId])
  @@map("feature_sets")
}

// A feature whose lifecycle is driven by the `feature` state machine (RF4.2).
// Weighted progress (RF4.3) is computed from feature statuses in the domain.
model Feature {
  id           String        @id @default(uuid()) @db.Uuid
  featureSetId String        @map("feature_set_id") @db.Uuid
  title        String
  estimate     Int?
  // Optional owner in team workspaces. References auth.users(id); no FK.
  ownerId      String?       @map("owner_id") @db.Uuid
  status       FeatureStatus @default(design)
  position     Int           @default(0)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  featureSet   FeatureSet           @relation(fields: [featureSetId], references: [id], onDelete: Cascade)
  statusEvents FeatureStatusEvent[]
  tasks        Task[]

  @@index([featureSetId])
  @@map("features")
}

// Event table: INSERT-only feature status log (RF4.4 weekly progress derives here).
model FeatureStatusEvent {
  id         String         @id @default(uuid()) @db.Uuid
  featureId  String         @map("feature_id") @db.Uuid
  fromStatus FeatureStatus? @map("from_status")
  toStatus   FeatureStatus  @map("to_status")
  actorId    String         @map("actor_id") @db.Uuid
  at         DateTime       @default(now()) @db.Timestamptz(6)

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
  @@index([at])
  @@map("feature_status_events")
}

// --- Traceability (M7) ----------------------------------------------------

// A directed relation between two goals (RF7.4): depends_on / refines /
// conflicts. Conflicts drive alerts in the matrix view.
model GoalLink {
  id         String       @id @default(uuid()) @db.Uuid
  fromGoalId String       @map("from_goal_id") @db.Uuid
  toGoalId   String       @map("to_goal_id") @db.Uuid
  type       GoalLinkType
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  fromGoal Goal @relation("GoalLinkFrom", fields: [fromGoalId], references: [id], onDelete: Cascade)
  toGoal   Goal @relation("GoalLinkTo", fields: [toGoalId], references: [id], onDelete: Cascade)

  @@unique([fromGoalId, toGoalId, type])
  @@index([fromGoalId])
  @@index([toGoalId])
  @@map("goal_links")
}

// --- Routine prototyping (M8) ---------------------------------------------

// A routine prototyped either throwaway or evolutionary (RF8.1).
model Routine {
  id            String        @id @default(uuid()) @db.Uuid
  workspaceId   String        @map("workspace_id") @db.Uuid
  ownerId       String        @map("owner_id") @db.Uuid
  name          String
  prototypeKind PrototypeKind @map("prototype_kind")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions  RoutineVersion[]

  @@index([workspaceId])
  @@map("routines")
}

// A numbered version of a routine (RF8.2), closed with a justified decision (RF8.4).
model RoutineVersion {
  id            String           @id @default(uuid()) @db.Uuid
  routineId     String           @map("routine_id") @db.Uuid
  number        Int
  startedAt     DateTime         @default(now()) @map("started_at") @db.Timestamptz(6)
  closedAt      DateTime?        @map("closed_at") @db.Timestamptz(6)
  decision      RoutineDecision?
  justification String?

  routine      Routine              @relation(fields: [routineId], references: [id], onDelete: Cascade)
  requirements RoutineRequirement[]

  @@unique([routineId, number])
  @@index([routineId])
  @@map("routine_versions")
}

// A requirement to validate within a version (RF8.2). `inheritedFrom` links to
// the requirement it was carried over from when a version evolves (RF8.4).
model RoutineRequirement {
  id            String   @id @default(uuid()) @db.Uuid
  versionId     String   @map("version_id") @db.Uuid
  text          String
  inheritedFrom String?  @map("inherited_from") @db.Uuid
  position      Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  version     RoutineVersion       @relation(fields: [versionId], references: [id], onDelete: Cascade)
  source      RoutineRequirement?  @relation("RequirementInheritance", fields: [inheritedFrom], references: [id], onDelete: SetNull)
  inheritedBy RoutineRequirement[] @relation("RequirementInheritance")
  evaluations RoutineEvaluation[]

  @@index([versionId])
  @@map("routine_requirements")
}

// Event table: a daily evaluation of one requirement (RF8.3). In teams several
// members evaluate the same requirement/day and results are consolidated (RF8.6).
model RoutineEvaluation {
  id            String           @id @default(uuid()) @db.Uuid
  requirementId String           @map("requirement_id") @db.Uuid
  evaluatorId   String           @map("evaluator_id") @db.Uuid
  date          DateTime         @db.Date
  result        EvaluationResult
  note          String?
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  requirement RoutineRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, evaluatorId, date])
  @@index([requirementId])
  @@map("routine_evaluations")
}
