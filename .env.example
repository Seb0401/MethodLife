# Supabase — valores públicos del proyecto (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Prisma — cadena de conexión a Postgres (Dashboard → Connect). Van en `.env`
# (Prisma no lee `.env.local`). App: pooler de transacciones (6543);
# migraciones: pooler de sesión (5432).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"
